# ── Faucet configuration ───────────────────────────────────────────────
# Copy to .env and fill in. In Docker, the compose file sets the *_URL values
# for the bundled services, so you mainly need the indexer key, a session
# secret, and client creds below. Most of these can also be edited live from
# the in-app Settings panel once you're signed in.

# ── Authentication ──
# Signing key for session cookies. SET THIS to a long random string so logins
# survive restarts. If left blank, Faucet generates one and stores it, but a
# fixed value is strongly preferred. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=
# Session lifetime (days), and brute-force lockout tuning.
SESSION_DAYS=30
LOGIN_MAX_FAILED=5
LOGIN_LOCK_MINUTES=15
# Note: the FIRST account you register in the UI becomes the admin.

# ── Indexer (Jackett or Prowlarr Torznab) ──
# Get the API key from the Jackett dashboard (top-right). Add a few indexers there.
JACKETT_API_KEY=
# "all" queries every indexer you've configured. Or set a specific tracker id.
JACKETT_INDEXER=all
# Only needed for bare-metal (compose overrides this):
# JACKETT_URL=http://127.0.0.1:9117

# ── Download client ──
# One of: transmission | qbittorrent | deluge
DOWNLOAD_CLIENT=transmission
# Credentials for the client's web/RPC interface.
CLIENT_USER=faucet
CLIENT_PASS=changeme
# Only needed for bare-metal (compose overrides this):
# CLIENT_URL=http://127.0.0.1:9091/transmission/rpc

# ── Paths ──
# Where finished media is filed (movies/ and tvshows/ are created under here).
LIBRARY_ROOT=/library
# Active download directory (keep on fast local disk).
DOWNLOAD_DIR=/downloads
# Volume to report free space on in the stats bar.
DISK_PATH=/downloads
# Root the admin file browser is scoped to (defaults to LIBRARY_ROOT).
# BROWSE_ROOT=/library

# Host paths the containers mount (used by docker-compose):
LIBRARY_PATH=./library
DOWNLOADS_PATH=./downloads
PUID=1000
PGID=1000
TZ=Etc/UTC

# ── Behavior ──
REQUEST_TIMEOUT=30
SEARCH_LIMIT=150
BIG_DOWNLOAD_GB=20
# Auto-remove finished torrents from the client (stops seeding). 1=on 0=off.
REMOVE_ON_COMPLETE=0

# ── Notifications ──
# Comma-separated targets. Leave blank to disable. Shorthand schemes:
#   discord://<webhook_id>/<token>
#   telegram://<bot_token>/<chat_id>
#   ntfy://ntfy.sh/<topic>
#   gotify://<host>/<app_token>
#   https://example.com/your-webhook   (generic JSON POST)
NOTIFY_URLS=
# Which events fire a notification: completed, sorted, failed
NOTIFY_ON=completed,sorted,failed

# ── UI ──
# Default theme: dark | light. Each user can toggle their own preference.
UI_THEME=dark
# Title shown in the app.
APP_TITLE=Faucet

# ── Metadata (TMDb) ──
# Optional but recommended. Enables search-by-title with posters and episode
# tracking. Free key from https://www.themoviedb.org/settings/api .
# Usually set in the UI under Settings (stored in the database).
TMDB_API_KEY=

# ── Auto-grab scheduler ──
# How often (seconds) Faucet scans/reconciles/hunts. Default 1800 (30 min).
RSS_INTERVAL_SECONDS=1800

# ── Auto-grab concurrency caps ──
# Don't hunt if this many torrents are already downloading (default 5).
HUNT_MAX_ACTIVE=5
# Grab at most this many wanted items per scheduler tick (default 3).
HUNT_MAX_PER_RUN=3
